{
  "manifest_version": 3,
  "name": "Klaudii",
  "version": "1.0.0",
  "description": "Manage your Claude Code sessions from Chrome's side panel",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "https://localhost:*/*",
    "http://127.0.0.1:*/*",
    "http://10.*.*.*:*/*",
    "http://192.168.*.*:*/*",
    "http://172.16.*.*:*/*",
    "https://claude.ai/*",
    "https://konnect.klaudii.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://konnect.klaudii.com/*"],
      "js": ["connect-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Klaudii — Manage Claude Sessions"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
